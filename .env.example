# Calmate - 環境変数設定

# === 必須 ===

# Google OAuth (Google Cloud Consoleで取得)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Google Calendar用リダイレクトURI（省略時はGOOGLE_REDIRECT_URIから自動生成）
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# MySQL データベース
DATABASE_URL=mysql://user:password@localhost:3306/calmate

# JWT セッション署名キー（任意の長いランダム文字列）
JWT_SECRET=your-random-secret-key-here

# === オプション ===

# 管理者ユーザーのGoogle sub ID
# OWNER_OPEN_ID=

# API Base URL（モバイルアプリ用）
# EXPO_PUBLIC_API_BASE_URL=https://your-server.com

# Google OAuth クライアントID（Expo用、カレンダー連携に使用）
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
